{
  "name": "iface",
  "private": true,
  "version": "1.4.2",
  "type": "module",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "npm run build:electron && concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_ELECTRON=1 electron .\"",
    "build": "tsc -b && vite build",
    "build:electron": "rollup -c scripts/rollup.electron.config.mjs",
    "build:electron:prod": "tsc -b && cross-env VITE_ELECTRON=1 vite build && rollup -c scripts/rollup.electron.config.mjs",
    "typecheck:electron:main": "tsc --noEmit -p tsconfig.main.json",
    "typecheck:electron:preload": "tsc --noEmit -p tsconfig.preload.json",
    "typecheck:electron": "npm run typecheck:electron:main && npm run typecheck:electron:preload",
    "preview": "vite preview",
    "build:backend": "pnpm --filter iface-backend build",
    "dev:backend": "pnpm --filter iface-backend dev",
    "typecheck:backend": "pnpm --filter iface-backend typecheck",
    "electron": "electron ."
  },
  "dependencies": {
    "axios": "^1.18.0",
    "clsx": "^2.1.1",
    "idb": "^8.0.3",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.4",
    "electron": "^42.4.1",
    "rollup": "^4.40.1",
    "tslib": "^2.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^8.0.3"
  }
}
